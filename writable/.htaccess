# ============================================================
# SECURITY: Blokir akses HTTP ke seluruh folder writable/
# Ini adalah writable/ CI4 — bukan untuk akses publik
# ============================================================
# Ditambahkan oleh: MASSIPA Security Patch 14/04/2026
# ============================================================

# Apache 2.2
Order allow,deny
Deny from all

# Apache 2.4+ (mod_authz_core.c)
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
